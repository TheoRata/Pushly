# Pushly Configuration
# Copy this file to .env and adjust as needed.

# Server port (default: 3000, auto-detects 3000-3010 if occupied)
# PORT=3000

# Mode: "local" for shared-drive deployment, "cloud" for hosted (future)
# MODE=local

# Salesforce Connected App (required for OAuth login)
# Create a Connected App in Salesforce Setup > App Manager
# SF_CLIENT_ID=your_consumer_key
# SF_CLIENT_SECRET=your_consumer_secret
# SF_CALLBACK_URL=http://localhost:3000/api/oauth/callback
